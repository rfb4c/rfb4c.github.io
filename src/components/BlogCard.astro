---
interface Props {
  title: string;
  date: string;
  description: string;
  slug: string;
}

const { title, date, description, slug } = Astro.props;
---
<article class="group border border-gray-100 dark:border-white/10 rounded-xl p-5 hover:border-gray-200 dark:hover:border-white/20 transition-all duration-200">
  <time class="text-xs text-gray-400 dark:text-zinc-500">{date}</time>
  <h3 class="mt-1 text-sm font-medium text-[#111111] dark:text-[#FAFAFA] group-hover:text-[#7C3AED] dark:group-hover:text-[#A78BFA] transition-colors leading-snug">
    {title}
  </h3>
  <p class="mt-2 text-sm text-gray-500 dark:text-zinc-400 line-clamp-2 leading-relaxed">{description}</p>
  <a
    href={`/blog/${slug}`}
    class="mt-3 inline-flex items-center gap-1 text-xs text-[#7C3AED] dark:text-[#A78BFA]"
    aria-label={`Read ${title}`}
  >
    Read
    <svg class="w-3 h-3 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
  </a>
</article>
