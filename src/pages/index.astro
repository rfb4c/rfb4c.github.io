---
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogCard from '../components/BlogCard.astro';
import { getCollection } from 'astro:content';
import { featuredWorks } from '../data/writing';

const posts = await getCollection('blog');
const latestPosts = posts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 2);
---

<BaseLayout title="Ash Feng">

  <!-- Hero -->
  <section class="relative overflow-hidden pt-16 pb-12">
    <!-- Diffuse light blobs -->
    <div class="absolute top-0 right-0 w-[480px] h-[480px] pointer-events-none select-none" aria-hidden="true">
      <div class="absolute top-4 right-4 w-80 h-80 rounded-full blur-3xl bg-[#7C3AED] opacity-20 dark:opacity-30"></div>
      <div class="absolute top-24 right-16 w-64 h-64 rounded-full blur-3xl bg-[#F97316] opacity-20 dark:opacity-30"></div>
      <div class="absolute top-8 right-52 w-48 h-48 rounded-full blur-3xl bg-[#06B6D4] opacity-15 dark:opacity-20"></div>
    </div>

    <div class="max-w-2xl mx-auto px-6 relative">
      <!-- Profile row -->
      <div class="mb-8">
        <h1 class="text-xl font-semibold tracking-tight">Ash Feng</h1>
        <p class="mt-0.5 text-sm text-gray-500 dark:text-zinc-400">Consultant & AI Engineer · Former Journalist in China</p>
        <p class="text-xs text-gray-400 dark:text-zinc-500 mt-0.5">Nagoya, Japan</p>
      </div>

      <p class="text-sm text-gray-500 dark:text-zinc-400 mb-5">Designing media environments for mutual understanding.</p>

      <!-- Research interest tags -->
      <div class="flex flex-wrap gap-2">
        {['Perceptual Polarization', 'Media Design', 'HCI', 'Computational Communication'].map(tag => (
          <span class="text-xs px-3 py-1 rounded-full border border-gray-200 dark:border-white/15 text-gray-500 dark:text-zinc-400">
            {tag}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- About -->
  <section class="pb-14">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="text-[10px] font-semibold uppercase tracking-[0.15em] text-gray-400 dark:text-zinc-500 mb-5">About</h2>
      <div class="space-y-4 text-[15px] text-gray-600 dark:text-zinc-300 leading-relaxed">
        <p>
          I design and study media environments that help people understand each other better across difference.
          My research focuses on <span class="text-[#111111] dark:text-[#FAFAFA] font-medium">perceptual polarization</span> —
          the systematic exaggeration of how extreme and hostile the other side really is — and how platform
          architecture can be redesigned to correct rather than amplify these distortions.
        </p>
        <p>
          My background spans communication research, journalism, and software engineering — a combination
          I built to do work that requires both theoretical grounding and the technical capacity to
          construct the systems it proposes.
        </p>
      </div>

    </div>
  </section>

  <div class="max-w-2xl mx-auto px-6">
    <hr class="border-gray-100 dark:border-white/10" />
  </div>

  <!-- Experience -->
  <section class="py-14">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="text-[10px] font-semibold uppercase tracking-[0.15em] text-gray-400 dark:text-zinc-500 mb-6">Experience</h2>
      <div class="space-y-8">

        <div class="flex gap-4">
          <div class="flex flex-col items-center pt-1">
            <div class="w-1.5 h-1.5 rounded-full bg-gray-300 dark:bg-zinc-600 shrink-0"></div>
            <div class="w-px flex-1 bg-gray-100 dark:bg-white/10 mt-2"></div>
          </div>
          <div class="pb-2">
            <div class="flex items-baseline gap-2 flex-wrap">
              <span class="text-sm font-medium text-[#111111] dark:text-[#FAFAFA]">Accenture Japan</span>
              <span class="text-xs text-gray-400 dark:text-zinc-500">Nagoya · Jul 2025–Present</span>
            </div>
            <p class="text-xs text-gray-500 dark:text-zinc-400 mt-0.5">Consultant & AI Solutions Engineer (Forward Deployed Engineer)</p>
            <div class="mt-2 space-y-3">
              <div>
                <p class="text-xs text-gray-400 dark:text-zinc-500 mb-1">Major energy group · Development lead</p>
                <p class="text-sm text-gray-500 dark:text-zinc-400 leading-relaxed">
                  Designed and built an AI workflow that auto-generates Java error-checking code end-to-end — from requirements through TDD — combining LLM and MCP. Led client negotiation, requirements alignment, and weekly reviews; standardized outputs as reusable, person-independent templates.
                </p>
              </div>
              <div>
                <p class="text-xs text-gray-400 dark:text-zinc-500 mb-1">Metropolitan government international PR department · Development member</p>
                <p class="text-sm text-gray-500 dark:text-zinc-400 leading-relaxed">
                  Building an AI agent pipeline that automates multilingual public communications record generation — directly adjacent to my research on AI-mediated information production.
                </p>
              </div>
            </div>
            <p class="text-xs text-gray-400 dark:text-zinc-500 mt-3">Java · Python · MCP · LLM · Prompt Engineering · TDD</p>
          </div>
        </div>

        <div class="flex gap-4">
          <div class="flex flex-col items-center pt-1">
            <div class="w-1.5 h-1.5 rounded-full bg-gray-300 dark:bg-zinc-600 shrink-0"></div>
            <div class="w-px flex-1 bg-gray-100 dark:bg-white/10 mt-2"></div>
          </div>
          <div class="pb-2">
            <div class="flex items-baseline gap-2 flex-wrap">
              <span class="text-sm font-medium text-[#111111] dark:text-[#FAFAFA]">Neutral Co., Ltd.</span>
              <span class="text-xs text-gray-400 dark:text-zinc-500">Nagoya · Jul 2023–Jun 2025</span>
            </div>
            <p class="text-xs text-gray-500 dark:text-zinc-400 mt-0.5">System Engineer</p>
            <p class="text-sm text-gray-500 dark:text-zinc-400 mt-2 leading-relaxed">
              Full-stack development for a major automotive manufacturer's vehicle design systems. Designed and implemented features across UI, API, and database layers; participated in full agile lifecycle from requirements to release.
            </p>
            <p class="text-xs text-gray-400 dark:text-zinc-500 mt-2">Java · Spring Boot · Angular.js · Oracle · Jenkins</p>
          </div>
        </div>

        <div class="flex gap-4">
          <div class="flex flex-col items-center pt-1">
            <div class="w-1.5 h-1.5 rounded-full bg-gray-300 dark:bg-zinc-600 shrink-0"></div>
            <div class="w-px flex-1 bg-gray-100 dark:bg-white/10 mt-2"></div>
          </div>
          <div class="pb-2">
            <div class="flex items-baseline gap-2 flex-wrap">
              <span class="text-sm font-medium text-[#111111] dark:text-[#FAFAFA]">The Cover (封面新闻)</span>
              <span class="text-xs text-gray-400 dark:text-zinc-500">Beijing · Jul–Nov 2022</span>
            </div>
            <p class="text-xs text-gray-500 dark:text-zinc-400 mt-0.5">Journalist</p>
            <p class="text-sm text-gray-500 dark:text-zinc-400 mt-2 leading-relaxed">
              Covered science, technology, and breaking news. Produced a documentary series on national infrastructure projects (Chinese Journalism Award). Conducted an investigation into COVID survivor employment discrimination that prompted a State Council policy response.
            </p>
          </div>
        </div>

        <div class="flex gap-4">
          <div class="flex flex-col items-center pt-1">
            <div class="w-1.5 h-1.5 rounded-full bg-gray-300 dark:bg-zinc-600 shrink-0"></div>
            <div class="w-px flex-1 bg-gray-100 dark:bg-white/10 mt-2"></div>
          </div>
          <div class="pb-2">
            <div class="flex items-baseline gap-2 flex-wrap">
              <span class="text-sm font-medium text-[#111111] dark:text-[#FAFAFA]">The Paper (澎湃新闻)</span>
              <span class="text-xs text-gray-400 dark:text-zinc-500">Shanghai · 2021–2022</span>
            </div>
            <p class="text-xs text-gray-500 dark:text-zinc-400 mt-0.5">Intern Journalist</p>
            <p class="text-sm text-gray-500 dark:text-zinc-400 mt-2 leading-relaxed">
              Photojournalism, exhibition coverage, and multimedia production including VR dispatches. Produced an independent documentary on Chinese students stranded in Japan during the early pandemic.
            </p>
          </div>
        </div>

        <div class="flex gap-4">
          <div class="flex flex-col items-center pt-1">
            <div class="w-1.5 h-1.5 rounded-full bg-gray-300 dark:bg-zinc-600 shrink-0"></div>
            <div class="w-px flex-1 bg-gray-100 dark:bg-white/10 mt-2"></div>
          </div>
          <div class="pb-2">
            <div class="flex items-baseline gap-2 flex-wrap">
              <span class="text-sm font-medium text-[#111111] dark:text-[#FAFAFA]">Kansai University</span>
              <span class="text-xs text-gray-400 dark:text-zinc-500">Japan · 2020–2022</span>
            </div>
            <p class="text-xs text-gray-500 dark:text-zinc-400 mt-0.5">M.A. Sociology (Mass Communication)</p>
          </div>
        </div>

        <div class="flex gap-4">
          <div class="flex flex-col items-center pt-1">
            <div class="w-1.5 h-1.5 rounded-full bg-gray-300 dark:bg-zinc-600 shrink-0"></div>
          </div>
          <div>
            <div class="flex items-baseline gap-2 flex-wrap">
              <span class="text-sm font-medium text-[#111111] dark:text-[#FAFAFA]">Shanghai Polytechnic University</span>
              <span class="text-xs text-gray-400 dark:text-zinc-500">Shanghai · 2014–2018</span>
            </div>
            <p class="text-xs text-gray-500 dark:text-zinc-400 mt-0.5">B.A. Japanese & English</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <div class="max-w-2xl mx-auto px-6">
    <hr class="border-gray-100 dark:border-white/10" />
  </div>

  <!-- Research -->
  <section class="py-14">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="text-[10px] font-semibold uppercase tracking-[0.15em] text-gray-400 dark:text-zinc-500 mb-5">Research</h2>
      <p class="text-[15px] text-gray-600 dark:text-zinc-300 leading-relaxed mb-8">
        I study <span class="text-[#111111] dark:text-[#FAFAFA] font-medium">perceptual polarization</span> — the systematic exaggeration of how extreme and hostile the other side really is. Evidence suggests that digital algorithms distort not political attitudes directly, but the informational inputs people use to <em>infer</em> out-group beliefs and in-group norms; this makes the inference layer the more tractable intervention target. My current research develops the <span class="text-[#111111] dark:text-[#FAFAFA] font-medium">Perceived Depolarization Design Framework (PDDF)</span>, which translates cognitive causal mechanisms into platform-agnostic intervention functions and tests them via randomized controlled experiments in a custom-built high-fidelity social feed simulator.
      </p>
      <div class="space-y-6">

        <div>
          <div class="flex items-baseline justify-between gap-4 flex-wrap">
            <span class="text-sm font-medium text-[#111111] dark:text-[#FAFAFA]">Patriotic Propaganda in Crisis</span>
            <span class="text-xs text-gray-400 dark:text-zinc-500">M.A. Thesis · 2022</span>
          </div>
          <p class="text-sm text-gray-500 dark:text-zinc-400 mt-1.5 leading-relaxed">
            A content analysis of People's Daily's WeChat account (n = 2,318 posts, January–April 2020), examining how Chinese state media deploys patriotic propaganda during a public health crisis. Identified four structural mechanisms: layered deployment of narrative categories, threshold-triggered responsiveness to political events, resilient adaptation under narrative challenges, and embodied transmission through representative identities.
          </p>
          <p class="text-xs text-gray-400 dark:text-zinc-500 mt-2">Content analysis · Chinese media · Political communication · Mass Communication</p>
        </div>

        <div>
          <div class="flex items-baseline justify-between gap-4 flex-wrap">
            <span class="text-sm font-medium text-[#111111] dark:text-[#FAFAFA]">Lichtung <span class="font-normal text-gray-400 dark:text-zinc-500">(林地空间)</span></span>
            <a href="https://lichtung-three.vercel.app" target="_blank" rel="noopener noreferrer" class="text-xs text-[#7C3AED] dark:text-[#A78BFA] hover:opacity-70 transition-opacity">lichtung-three.vercel.app ↗</a>
          </div>
          <p class="text-sm text-gray-500 dark:text-zinc-400 mt-1.5 leading-relaxed">
            A high-fidelity social feed simulator with two depolarization interventions implemented — the experimental platform for my PhD research proposal. Built to test whether algorithmic design can reduce perceptual polarization.
          </p>
          <p class="text-xs text-gray-400 dark:text-zinc-500 mt-2">Research prototype · Feed ranking · AI agent · Behavioral telemetry</p>
        </div>

        <div>
          <div class="flex items-baseline justify-between gap-4 flex-wrap">
            <span class="text-sm font-medium text-[#111111] dark:text-[#FAFAFA]">r-selected</span>
            <span class="text-xs text-gray-400 dark:text-zinc-500">Retired prototype · preceded Lichtung</span>
          </div>
          <p class="text-sm text-gray-500 dark:text-zinc-400 mt-1.5 leading-relaxed">
            A multi-perspective news aggregator enabling side-by-side comparison of coverage across outlets on the same event. The original prototype that led me to question filter bubble theory.
          </p>
          <p class="text-xs text-gray-400 dark:text-zinc-500 mt-2">Java · Angular.js · Vue.js · MySQL · AWS EC2 · Docker</p>
        </div>

      </div>
    </div>
  </section>

  <div class="max-w-2xl mx-auto px-6">
    <hr class="border-gray-100 dark:border-white/10" />
  </div>

  <!-- Blog preview -->
  <section class="py-14">
    <div class="max-w-2xl mx-auto px-6">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-[10px] font-semibold uppercase tracking-[0.15em] text-gray-400 dark:text-zinc-500">From the Blog</h2>
        <a href="/blog" class="text-xs text-[#7C3AED] dark:text-[#A78BFA] hover:opacity-70 transition-opacity">
          All posts →
        </a>
      </div>
      {latestPosts.length > 0 ? (
        <div class="grid sm:grid-cols-2 gap-4">
          {latestPosts.map(post => (
            <BlogCard
              title={post.data.title}
              date={post.data.date.toISOString().split('T')[0]}
              description={post.data.description}
              slug={post.slug}
            />
          ))}
        </div>
      ) : (
        <p class="text-sm text-gray-400 dark:text-zinc-500">No posts yet.</p>
      )}
    </div>
  </section>

  <div class="max-w-2xl mx-auto px-6">
    <hr class="border-gray-100 dark:border-white/10" />
  </div>

  <!-- Writing preview -->
  <section class="py-14">
    <div class="max-w-2xl mx-auto px-6">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-[10px] font-semibold uppercase tracking-[0.15em] text-gray-400 dark:text-zinc-500">Journalism</h2>
        <a href="/writing" class="text-xs text-[#7C3AED] dark:text-[#A78BFA] hover:opacity-70 transition-opacity">
          All work →
        </a>
      </div>
      {(() => {
        const documentary = featuredWorks.find(w => w.type === 'Documentary')!;
        const investigation = featuredWorks.find(w => w.type === 'Investigation')!;
        const photography = featuredWorks.find(w => w.type === 'Photography')!;
        return (
          <div class="space-y-3">

            <!-- Investigation — top, most prominent, image + strong overlay -->
            <a href={investigation.url} target="_blank" rel="noopener noreferrer"
               class="group relative block rounded-xl overflow-hidden aspect-[2/1]">
              <img src={investigation.image} alt={investigation.title}
                   class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
              <div class="absolute inset-0 bg-gradient-to-r from-black/80 via-black/40 to-transparent"></div>
              <div class="absolute inset-0 p-5 flex flex-col justify-between">
                <span class="text-[10px] font-semibold uppercase tracking-[0.12em] text-white/50">{investigation.type} · {investigation.publication} · {investigation.year}</span>
                <div>
                  <h3 class="text-base font-semibold text-white leading-snug mb-2">{investigation.title}</h3>
                  <p class="text-xs text-white/60 leading-relaxed line-clamp-2 max-w-[60%]">{investigation.description}</p>
                  {investigation.note && <p class="mt-2 text-[10px] text-[#FB923C]">{investigation.note}</p>}
                </div>
              </div>
            </a>

            <!-- Photography — middle, wide landscape crop -->
            <a href={photography.url} target="_blank" rel="noopener noreferrer"
               class="group relative block rounded-xl overflow-hidden aspect-[16/9]">
              <img src={photography.image} alt={photography.title}
                   class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
              <div class="absolute inset-0 bg-gradient-to-t from-black/65 via-transparent to-transparent"></div>
              <div class="absolute bottom-0 left-0 right-0 p-4">
                <p class="text-[10px] font-semibold uppercase tracking-[0.12em] text-white/50">{photography.type} · {photography.publication} · {photography.year}</p>
                <h3 class="mt-1 text-sm font-semibold text-white leading-snug">{photography.title}</h3>
              </div>
            </a>

            <!-- Documentary — bottom, cinematic letterbox -->
            <a href={documentary.url} target="_blank" rel="noopener noreferrer"
               class="group relative block rounded-xl overflow-hidden bg-black aspect-[2/1]">
              <div class="absolute inset-x-0 top-[11%] bottom-[11%]">
                <img src={documentary.image} alt={documentary.title}
                     class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
              </div>
              <div class="absolute inset-x-0 bottom-0 h-[45%] bg-gradient-to-t from-black/80 to-transparent pointer-events-none"></div>
              <div class="absolute inset-0 flex items-center justify-center">
                <div class="w-12 h-12 rounded-full bg-white/15 backdrop-blur-sm border border-white/20 flex items-center justify-center group-hover:bg-white/30 group-hover:scale-105 transition-all duration-200">
                  <svg class="w-5 h-5 text-white ml-0.5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M8 5v14l11-7z"/>
                  </svg>
                </div>
              </div>
              <div class="absolute bottom-0 left-0 right-0 p-4">
                <p class="text-[10px] font-semibold uppercase tracking-[0.12em] text-white/40">{documentary.type} · {documentary.publication} · {documentary.year}</p>
                <h3 class="mt-1 text-sm font-semibold text-white leading-snug">{documentary.title}</h3>
              </div>
            </a>

          </div>
        );
      })()}
    </div>
  </section>

</BaseLayout>
