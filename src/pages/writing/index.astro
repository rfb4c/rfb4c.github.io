---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { featuredWorks, writingSeries } from '../../data/writing';

const typeLabel: Record<string, string> = {
  Documentary: 'Documentary',
  Investigation: 'Investigation',
  Photography: 'Photography',
};
---

<BaseLayout title="Writing — Rui Feng" description="Journalism from 2021–2022 spanning photography, documentary, and investigative reporting.">
  <section class="px-6 py-16">
    <div class="max-w-2xl mx-auto">

      <h1 class="text-2xl font-semibold tracking-tight mb-1">Writing</h1>
      <p class="text-sm text-gray-500 dark:text-zinc-400 mb-14">
        Journalism from 2021–2022 across photography, documentary, and investigative reporting.
      </p>

      <!-- Featured -->
      <h2 class="text-[10px] font-semibold uppercase tracking-[0.15em] text-gray-400 dark:text-zinc-500 mb-5">Featured</h2>
      <div class="grid sm:grid-cols-3 gap-4 mb-16">
        {featuredWorks.map(work => (
          <a
            href={work.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group block rounded-xl overflow-hidden border border-gray-100 dark:border-white/10 hover:border-gray-200 dark:hover:border-white/20 transition-all duration-200"
          >
            <!-- Cover image -->
            <div class="aspect-[4/3] overflow-hidden bg-gray-100 dark:bg-white/5">
              <img
                src={work.image}
                alt={work.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              />
            </div>
            <!-- Card body -->
            <div class="p-4">
              <span class="text-[10px] font-semibold uppercase tracking-[0.12em] text-[#7C3AED] dark:text-[#A78BFA]">
                {typeLabel[work.type]}
              </span>
              <h3 class="mt-1 text-sm font-medium text-[#111111] dark:text-[#FAFAFA] leading-snug line-clamp-2">
                {work.title}
              </h3>
              <p class="mt-2 text-xs text-gray-500 dark:text-zinc-400 leading-relaxed line-clamp-3">
                {work.description}
              </p>
              {work.note && (
                <p class="mt-2 text-[10px] text-[#F97316] dark:text-[#FB923C]">{work.note}</p>
              )}
              <div class="mt-3 flex items-center justify-between">
                <span class="text-xs text-gray-400 dark:text-zinc-500">{work.publication} · {work.year}</span>
                <svg class="w-3.5 h-3.5 text-gray-300 dark:text-zinc-600 group-hover:text-[#7C3AED] dark:group-hover:text-[#A78BFA] transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </div>
            </div>
          </a>
        ))}
      </div>

      <!-- Series -->
      <h2 class="text-[10px] font-semibold uppercase tracking-[0.15em] text-gray-400 dark:text-zinc-500 mb-4">Series</h2>
      <div class="space-y-2">
        {writingSeries.map(series => (
          <details class="group border border-gray-100 dark:border-white/10 rounded-xl overflow-hidden">
            <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none hover:bg-gray-50 dark:hover:bg-white/5 transition-colors">
              <div class="flex items-center gap-3 flex-wrap">
                <span class="text-sm font-medium text-[#111111] dark:text-[#FAFAFA]">{series.name}</span>
                {series.badge && (
                  <span class="text-[10px] px-2 py-0.5 rounded-full bg-[#F97316]/10 text-[#F97316] dark:text-[#FB923C] font-medium">
                    {series.badge}
                  </span>
                )}
                <span class="text-xs text-gray-400 dark:text-zinc-500">{series.publication} · {series.period} · {series.items.length} pieces</span>
              </div>
              <!-- Chevron -->
              <svg class="w-4 h-4 text-gray-400 dark:text-zinc-500 shrink-0 group-open:rotate-180 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-5 pb-4 border-t border-gray-100 dark:border-white/10">
              <p class="text-xs text-gray-500 dark:text-zinc-400 leading-relaxed mt-3 mb-4">{series.description}</p>
              <ul class="space-y-2">
                {series.items.map(item => (
                  <li>
                    <a
                      href={item.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="group/item flex items-center justify-between gap-3 text-sm text-gray-600 dark:text-zinc-300 hover:text-[#7C3AED] dark:hover:text-[#A78BFA] transition-colors"
                    >
                      <span class="flex items-center gap-2">
                        {item.note === 'video' && (
                          <span class="text-[10px] px-1.5 py-0.5 rounded bg-gray-100 dark:bg-white/10 text-gray-400 dark:text-zinc-500 font-medium shrink-0">VIDEO</span>
                        )}
                        {item.note === 'vr' && (
                          <span class="text-[10px] px-1.5 py-0.5 rounded bg-gray-100 dark:bg-white/10 text-gray-400 dark:text-zinc-500 font-medium shrink-0">VR</span>
                        )}
                        {item.note === 'archived' && (
                          <span class="text-[10px] px-1.5 py-0.5 rounded bg-gray-100 dark:bg-white/10 text-gray-400 dark:text-zinc-500 font-medium shrink-0">ARCHIVED</span>
                        )}
                        {item.title}
                      </span>
                      <svg class="w-3 h-3 text-gray-300 dark:text-zinc-600 group-hover/item:text-[#7C3AED] dark:group-hover/item:text-[#A78BFA] shrink-0 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                      </svg>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          </details>
        ))}
      </div>

    </div>
  </section>
</BaseLayout>
